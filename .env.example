# ─── JARVIS.AGI — Environment Configuration ───────────────────────────────────
# Copy this file to .env and fill in the values you want to use.
# Everything is optional — JARVIS gracefully skips unconfigured integrations.

# ── LLM Providers ─────────────────────────────────────────────────────────────
DEFAULT_LLM=ollama          # openai | anthropic | ollama
DEFAULT_MODEL=              # Override the default model name
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# ── Voice ─────────────────────────────────────────────────────────────────────
WAKE_WORD_MODEL=hey_jarvis  # hey_jarvis | hey_mycroft | alexa | or path to .onnx
WAKE_WORD_THRESHOLD=0.5
WHISPER_MODEL=base          # tiny | base | small | medium | large-v2
TTS_VOICE=en-US-AriaNeural  # Any edge-tts voice
TESSERACT_CMD=              # Path to tesseract.exe on Windows if not in PATH

# ── Speaker Recognition ───────────────────────────────────────────────────────
SPEAKER_PROFILE_DIR=.jarvis/speakers
SPEAKER_SIMILARITY_THRESHOLD=0.75

# ── Memory ────────────────────────────────────────────────────────────────────
MEMORY_ENABLED=true
CHROMA_PERSIST_DIR=.jarvis/chroma
KB_DIR=.jarvis/knowledge

# ── Server ────────────────────────────────────────────────────────────────────
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
TIMEZONE=UTC

# ── Phase 2: Google (Gmail, Calendar, Drive) ──────────────────────────────────
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_DRIVE_ENABLED=true

# ── Phase 2: Discord ──────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# ── Phase 2: YouTube ──────────────────────────────────────────────────────────
YOUTUBE_API_KEY=

# ── Phase 2: Instagram ────────────────────────────────────────────────────────
INSTAGRAM_USERNAME=
INSTAGRAM_PASSWORD=

# ── Phase 2: WhatsApp ─────────────────────────────────────────────────────────
WHATSAPP_ENABLED=false

# ── Phase 2: Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Phase 2: Spotify ──────────────────────────────────────────────────────────
SPOTIPY_CLIENT_ID=
SPOTIPY_CLIENT_SECRET=
SPOTIPY_REDIRECT_URI=http://localhost:8888/callback

# ── Phase 2: Slack ────────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=

# ── Phase 3: Browser ──────────────────────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=15000

# ── Phase 3: File System ──────────────────────────────────────────────────────
# Comma-separated list of directories JARVIS is allowed to access
FS_ALLOWED_DIRS=~/Documents,~/Downloads,~/Desktop

# ── Phase 3: Code Execution ───────────────────────────────────────────────────
CODE_EXEC_TIMEOUT=30
CODE_EXEC_WORKDIR=

# ── Phase 3: PyAutoGUI ────────────────────────────────────────────────────────
PYAUTOGUI_PAUSE=0.1

# ── Phase 5: Weather (no key needed) ─────────────────────────────────────────
# Nothing to configure — uses open-meteo.com

# ── Phase 5: News ─────────────────────────────────────────────────────────────
NEWSAPI_KEY=   # Optional — https://newsapi.org (free tier available)

# ── Phase 5: Notion ───────────────────────────────────────────────────────────
NOTION_TOKEN=

# ── Phase 5: GitHub ───────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ── Phase 5: Home Assistant ───────────────────────────────────────────────────
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=

# ── Phase 5: Finance (Plaid) ──────────────────────────────────────────────────
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox        # sandbox | development | production
PLAID_ACCESS_TOKEN=      # Obtained after completing OAuth flow
