# ── LLM Providers ─────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Default model provider: openai | anthropic | ollama
DEFAULT_LLM=openai
# Default model name (leave blank to use provider default)
DEFAULT_MODEL=gpt-4o

# ── Voice ─────────────────────────────────────────────────────────────────────
# tiny | base | small | medium | large-v3  (larger = more accurate, slower)
WHISPER_MODEL=base
# Path to a custom .onnx wake word model, or blank for built-in "hey_jarvis"
WAKE_WORD_MODEL=
# Microsoft Edge TTS voice name
TTS_VOICE=en-US-GuyNeural

# ── Google (Gmail + YouTube) ───────────────────────────────────────────────────
# Download from https://console.cloud.google.com -> APIs & Services -> Credentials
GOOGLE_CLIENT_SECRET_FILE=credentials.json

# ── Discord ───────────────────────────────────────────────────────────────────
# Create a bot at https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# ── Instagram ─────────────────────────────────────────────────────────────────
# Long-lived access token from https://developers.facebook.com
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
