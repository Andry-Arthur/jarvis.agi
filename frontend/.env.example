# Copy to `.env.local` for local overrides (not committed).
#
# This Next.js app uses same-origin calls (`/api/*` and `/ws`) and forwards them to
# the FastAPI backend using rewrites in `next.config.mjs`.
#
# Backend origins (defaults point at local dev server):
# JARVIS_HTTP_ORIGIN=http://localhost:8000
# JARVIS_WS_ORIGIN=ws://localhost:8000
# (Next rewrites require http/https destinations; ws/wss will be converted automatically.)
