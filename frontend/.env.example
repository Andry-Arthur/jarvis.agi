# Copy to `.env.local` for local overrides (not committed).

# When the UI is hosted separately from the API (e.g. Vercel + your own server),
# set the public origin of your JARVIS FastAPI app (https://..., no trailing slash).
# Leave unset for local dev (Vite proxies /api to localhost:8000).
# VITE_API_ORIGIN=https://your-api.example.com

# WebSocket URL for chat. In production use wss:// with the same host as the API.
# VITE_WS_URL=wss://your-api.example.com/ws
